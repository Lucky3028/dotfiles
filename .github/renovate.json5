{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>Lucky3028/renovate"],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update mise tools via Renovate annotation comments",
      "managerFilePatterns": ["/(^|/)mise/config\\.toml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+?) packageName=(?<packageName>[^\\s]+?)\\n(?<depName>[a-z-]+) = \"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["bitwarden/clients"],
      "extractVersion": "^cli-v(?<version>.+)$"
    },
    {
      "description": "uv 0.11.9 のリリースが GitHub Artifact Attestations を欠いているため一時的に無効化 (https://github.com/astral-sh/uv/issues/19278)",
      "matchPackageNames": ["astral-sh/uv"],
      "enabled": false
    }
  ]
}
