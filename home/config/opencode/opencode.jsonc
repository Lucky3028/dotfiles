{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "read": { "*": "ask", ".env": "deny", ".dev.vars": "deny", ".ssh/**": "deny" },
    "edit": { "*": "ask", ".env": "deny", ".dev.vars": "deny", ".ssh/**": "deny" },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "repo_clone": "allow",
    "repo_overview": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "doom_loop": "allow",
    "bash": {
      "*": "ask",
      // allow
      "curl*": "allow",
      "mkdir*": "allow",
      "touch*": "allow",
      "ls*": "allow",
      "tree*": "allow",
      "mv*": "allow",
      "cp*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "echo*": "allow",
      "sort*": "allow",
      "for*": "allow",
      "rm*": "allow",
      "wget*": "allow",
      "jj status*": "allow",
      "jj log*": "allow",
      "jj diff*": "allow",
      "jj show*": "allow",
      "jj file list*": "allow",
      "jj root*": "allow",
      "jj describe*": "allow",
      "jj new*": "allow",
      "jj edit*": "allow",
      "jj restore*": "allow",
      "jj squash*": "allow",
      "jj rebase*": "allow",
      "jj abandon*": "allow",
      "jj evolog*": "allow",
      "jj op log*": "allow",
      "jj operation log*": "allow",
      "jj undo*": "allow",
      "jj bookmark list*": "allow",
      "jj bookmark create*": "allow",
      "jj bookmark move*": "allow",
      "jj bookmark advance*": "allow",
      "jj bookmark set*": "allow",
      "jj bookmark rename*": "allow",
      "jj git fetch*": "allow",
      "jj config get*": "allow",
      "jj config list*": "allow",
      // deny
      "git*": "deny",
      "dd*": "deny",
      "sudo dd*": "deny",
      "su*": "deny",
      "sudo su*": "deny",
      "scp*": "deny",
      "rsync*": "deny",
      "service*": "deny",
      "sudo service*": "deny",
      "sudo systemctl poweroff*": "deny",
      "sudo systemctl reboot*": "deny",
      "sudo systemctl halt*": "deny",
      "sudo systemctl shutdown*": "deny",
      "shutdown*": "deny",
      "sudo shutdown*": "deny",
      "reboot*": "deny",
      "sudo reboot*": "deny",
      "poweroff*": "deny",
      "sudo poweroff*": "deny",
      "nc*": "deny",
      "jj split*": "deny",
      "jj resolve*": "deny",
      "jj diffedit*": "deny",
      "jj arrange*": "deny",
    },
  },
}
