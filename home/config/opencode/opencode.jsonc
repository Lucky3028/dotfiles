{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    // read: 基本許可、秘密鍵・デバイス・バイナリは拒否
    "read": {
      "*": "allow",
      // 秘密鍵を含むディレクトリ全体を拒否する。
      "**/.kube/**": "deny",
      "**/.ssh/**": "deny",
      // トークン・認証情報が含まれている可能性があるため拒否する。
      "**/.env*": "deny",
      "**/.dev.vars": "deny",
      "**/.npmrc": "deny",
      // デバイスファイルや擬似ファイルを読むとハングするため拒否する。
      "/dev/**": "deny",
      "/proc/**": "deny",
      "/sys/**": "deny",
      // ELFバイナリは読んでも意味がないため拒否する。
      "/bin/**": "deny",
      "/sbin/**": "deny",
      "/usr/bin/**": "deny",
      "/usr/sbin/**": "deny",
      "/usr/lib/**": "deny",
      // スワップファイル・ソケットも同様。
      "/swap*": "deny",
      "**/*.sock": "deny"
    },
    // edit: 基本許可、秘密鍵・デバイス・バイナリは拒否
    "edit": {
      "*": "allow",
      // 秘密鍵を含むディレクトリ全体を拒否する。
      "**/.kube/**": "deny",
      "**/.ssh/**": "deny",
      // トークン・認証情報が含まれている可能性があるため拒否する。
      "**/.env*": "deny",
      "**/.dev.vars": "deny",
      "**/.npmrc": "deny",
      // デバイスファイル・擬似ファイルに書き込むとハードウェア操作になるため拒否する。
      "/dev/**": "deny",
      "/proc/**": "deny",
      "/sys/**": "deny",
      // ELFバイナリは編集不能。スワップ・ソケットも同様。
      "/bin/**": "deny",
      "/sbin/**": "deny",
      "/usr/bin/**": "deny",
      "/usr/sbin/**": "deny",
      "/usr/lib/**": "deny",
      "/swap*": "deny",
      "**/*.sock": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "repo_clone": "allow",
    "repo_overview": "allow",
    "todowrite": "allow",
    "question": "allow",
    "skill": "allow",
    "task": "allow",
    "doom_loop": "allow",
    // bash: 基本確認、安全なものだけ許可、危険なものは拒否
    "bash": {
      "*": "ask",
      // 安全なファイル操作・ネットワーク取得
      "curl*": "allow",
      "mkdir*": "allow",
      "touch*": "allow",
      "ls*": "allow",
      "tree*": "allow",
      "mv*": "allow",
      "cp*": "allow",
      "cat*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "echo*": "allow",
      "sort*": "allow",
      "for*": "allow",
      "rm*": "allow",
      "wget*": "allow",
      // jj: 読み取り・undo可能な操作
      "jj status*": "allow",
      "jj log*": "allow",
      "jj diff*": "allow",
      "jj show*": "allow",
      "jj file list*": "allow",
      "jj root*": "allow",
      "jj describe*": "allow",
      "jj new*": "allow",
      "jj edit*": "allow",
      "jj restore*": "allow",
      "jj squash*": "allow",
      "jj rebase*": "allow",
      "jj abandon*": "allow",
      "jj evolog*": "allow",
      "jj op log*": "allow",
      "jj operation log*": "allow",
      "jj undo*": "allow",
      "jj bookmark list*": "allow",
      "jj bookmark create*": "allow",
      "jj bookmark move*": "allow",
      "jj bookmark advance*": "allow",
      "jj bookmark set*": "allow",
      "jj bookmark rename*": "allow",
      "jj git fetch*": "allow",
      "jj config get*": "allow",
      "jj config list*": "allow",
      // 危険・不可逆な操作
      "git*": "deny",
      "dd*": "deny",
      "sudo dd*": "deny",
      "su*": "deny",
      "sudo su*": "deny",
      "scp*": "deny",
      "rsync*": "deny",
      "service*": "deny",
      "sudo service*": "deny",
      "sudo systemctl poweroff*": "deny",
      "sudo systemctl reboot*": "deny",
      "sudo systemctl halt*": "deny",
      "sudo systemctl shutdown*": "deny",
      "shutdown*": "deny",
      "sudo shutdown*": "deny",
      "reboot*": "deny",
      "sudo reboot*": "deny",
      "poweroff*": "deny",
      "sudo poweroff*": "deny",
      "nc*": "deny",
      "jj split*": "deny",
      "jj resolve*": "deny",
      "jj diffedit*": "deny",
      "jj arrange*": "deny"
    }
  }
}
